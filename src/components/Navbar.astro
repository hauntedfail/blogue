---
import { Icon } from "astro-icon/components";
import { navBarConfig, siteConfig } from "../config";
import { getLocalizedLinkPresets } from "../constants/link-presets";
import { LinkPreset, type NavBarLink } from "../types/config";
import { getCurrentLocale, url } from "../utils/url-utils";
import LangSwitch from "./LangSwitch.svelte";
import LightDarkSwitch from "./LightDarkSwitch.svelte";
import Search from "./Search.svelte";
import DisplaySettings from "./widget/DisplaySettings.svelte";
import LiquidGlassButton from "./misc/LiquidGlassButton.svelte";
import NavMenuPanel from "./widget/NavMenuPanel.astro";

const className = Astro.props.class;

// Detect current locale from URL
const currentLocale = getCurrentLocale(Astro.url.pathname);
const localizedLinkPresets = getLocalizedLinkPresets(currentLocale);

let links: NavBarLink[] = navBarConfig.links.map(
	(item: NavBarLink | LinkPreset): NavBarLink => {
		if (typeof item === "number") {
			return localizedLinkPresets[item];
		}
		return item;
	},
);
---
<div id="navbar" class="z-50 onload-animation">
    <div class="absolute h-8 left-0 right-0 -top-8 bg-transparent transition"></div> <!-- used for onload animation -->
    <div class:list={[
        className,
        "relative overflow-visible bg-transparent max-w-[var(--page-width)] h-[4.5rem] mx-auto flex items-center justify-between px-4"]}>
        <LiquidGlassButton href={localizedLinkPresets[LinkPreset.Home].url} class="flex items-center justify-center scale-animation rounded-lg h-[3.25rem] px-5 font-bold active:scale-95 text-black/75 hover:text-[var(--primary)] dark:text-white/75 dark:hover:text-[var(--primary)]">
            <div class="flex flex-row text-[var(--primary)] items-center text-md">
                <Icon name="material-symbols:home-outline-rounded" class="text-[1.75rem] mb-1 mr-2" />
                {siteConfig.title}
            </div>
        </LiquidGlassButton>
        <div class="hidden md:flex">
            {links.map((l) => {
                return <LiquidGlassButton ariaLabel={l.name} href={l.external ? l.url : url(l.url)} target={l.external ? "_blank" : null}
                          class="flex items-center justify-center scale-animation rounded-lg h-11 font-bold px-5 active:scale-95 text-black/75 hover:text-[var(--primary)] dark:text-white/75 dark:hover:text-[var(--primary)]"
                >
                    <div class="flex items-center">
                        {l.name}
                        {l.external && <Icon name="line-md:external-link" class="text-[0.875rem] transition -translate-y-[1px] ml-1 text-black/[0.2] dark:text-white/[0.2]"></Icon>}
                    </div>
                </LiquidGlassButton>;
            })}
        </div>
        <div class="flex">
            <!--<SearchPanel client:load>-->
            <Search client:load></Search>
            {!siteConfig.themeColor.fixed && (
                    <LiquidGlassButton ariaLabel="Display Settings" class="flex items-center justify-center scale-animation rounded-lg h-11 w-11 active:scale-90 text-black/75 hover:text-[var(--primary)] dark:text-white/75 dark:hover:text-[var(--primary)]" id="display-settings-switch">
                        <Icon name="material-symbols:palette-outline" class="text-[1.25rem]"></Icon>
                    </LiquidGlassButton>
            )}
            <LangSwitch client:load initialLocale={currentLocale}></LangSwitch>
            <LightDarkSwitch client:load></LightDarkSwitch>
            <LiquidGlassButton ariaLabel="Menu" name="Nav Menu" class="flex items-center justify-center scale-animation rounded-lg w-11 h-11 active:scale-90 md:!hidden text-black/75 hover:text-[var(--primary)] dark:text-white/75 dark:hover:text-[var(--primary)]" id="nav-menu-switch">
                <Icon name="material-symbols:menu-rounded" class="text-[1.25rem]"></Icon>
            </LiquidGlassButton>
        </div>
        <NavMenuPanel links={links}></NavMenuPanel>
        {!siteConfig.themeColor.fixed && <DisplaySettings client:idle></DisplaySettings>}
    </div>
</div>

<script>
function loadButtonScript() {
    let settingBtn = document.getElementById("display-settings-switch");
    if (settingBtn) {
        settingBtn.onclick = function () {
            let settingPanel = document.getElementById("display-setting");
            if (settingPanel) {
                settingPanel.classList.toggle("float-panel-closed");
            }
        };
    }

    let menuBtn = document.getElementById("nav-menu-switch");
    if (menuBtn) {
        menuBtn.onclick = function () {
            let menuPanel = document.getElementById("nav-menu-panel");
            if (menuPanel) {
                menuPanel.classList.toggle("float-panel-closed");
            }
        };
    }
}

loadButtonScript();
</script>
